  {
    "id": 1,
    "arcana_name": "El Mago (Magician)",
    "arcana_image": "magician.jpg",
    "type": "split_character",
    "routes": {
      "male": {
        "character": "Kenji Tomochika",
        "location": "Aula 2-F",
        "availability": "Martes, Jueves, Viernes (Día)",
        "unlock_condition": "Disponible desde el 22 de Abril.",
        "image": "kenji.jpg",
        "ranks": [
          {
            "rank": 1,
            "type": "automatic",
            "interactions": [{"context": "Inicio", "options": [{"text": "Cualquiera", "points": 0}]}]
          },
          {
            "rank": 2,
            "interactions": [
              {
                "context": "Entonces, ¿puedes entrar a la habitación de Yukari-san y esas cosas?",
                "options": [
                  {"text": "Por supuesto.", "points": 0},
                  {"text": "No", "points": 2},
                  {"text": "Es un secreto", "points": 2}
                ]
              },
              {
                "context": "Cuando se trata de mujeres, me gusta que sean mayores que yo. ¿Y tú?",
                "options": [
                  {"text": "Me gustan las mujeres mayores", "points": 2},
                  {"text": "Me gustan las chicas de mi edad", "points": 0},
                  {"text": "Me gustan todas", "points": 2}
                ]
              }
            ]
          },
          {
            "rank": 3,
            "interactions": [
              {
                "context": "Tch! Amigo, estoy tan harto de esto...",
                "options": [
                  {"text": "Qué, ramen?", "points": 0},
                  {"text": "¿Qué, escuela?", "points": 0},
                  {"text": "¿Qué, la vida?", "points": 3}
                ]
              },
              {
                "context": "Bueno, [tu nombre], eso lo resuelve. ¡Voy a conseguirme una novia!",
                "options": [
                  {"text": "No puedes hacerlo.", "points": 0},
                  {"text": "Adelante.", "points": 2}
                ]
              }
            ]
          },
          {
            "rank": 4,
            "interactions": [
              {
                "context": "Oye, gracias por venir, hombre. ¿Puedes esperar aquí un segundo?",
                "options": [
                  {"text": "Claro.", "points": 0},
                  {"text": "¿Por qué?", "points": 3}
                ]
              },
              {
                "context": "Voy a invitar a salir a la Sra. ¡kanou ahora mismo!",
                "options": [
                  {"text": "¡Y que lo digas!", "points": 3},
                  {"text": "Cállate.", "points": 0}
                ]
              }
            ]
          },
          {
            "rank": 5,
            "interactions": [
              {
                "context": "Ayuda...",
                "options": [
                  {"text": "Por supuesto.", "points": 3},
                  {"text": "Si me pagas.", "points": 2}
                ]
              },
              {
                "context": "Coche...",
                "options": [
                  {"text": "Pronto tendrás una moto.", "points": 3},
                  {"text": "Dime cuando tengas coche.", "points": 2}
                ]
              }
            ]
          },
          {
            "rank": 6,
            "interactions": [
              {
                "context": "Problema...",
                "options": [
                  {"text": "Es un problema difícil.", "points": 3},
                  {"text": "Eres un adulto.", "points": 3}
                ]
              },
              {
                "context": "Ánimo...",
                "options": [
                  {"text": "¡Tú cállala!", "points": 3},
                  {"text": "¡No te rindas!", "points": 3}
                ]
              }
            ]
          },
          {
            "rank": 7,
            "interactions": [
              {
                "context": "Llamada...",
                "options": [
                  {"text": "Calla y supéralo.", "points": 3},
                  {"text": "¿Qué vas a hacer?", "points": 2}
                ]
              }
            ]
          },
          {
            "rank": 8,
            "interactions": [
              {
                "context": "Muerte...",
                "options": [
                  {"text": "Ella murió por una razón.", "points": 3},
                  {"text": "Simplemente murió.", "points": 2}
                ]
              }
            ]
          },
          {
            "rank": 9,
            "interactions": [
              {
                "context": "Pelea...",
                "options": [
                  {"text": "Sé fuerte, hombre.", "points": 3},
                  {"text": "Golpéame a mí también.", "points": 3}
                ]
              },
              {
                "context": "Amistad...",
                "options": [
                  {"text": "Por supuesto.", "points": 3},
                  {"text": "No sé.", "points": 0}
                ]
              }
            ]
          },
          {
            "rank": 10,
            "interactions": [
              {
                "context": "Final. Desbloquea: Mada.",
                "options": [{"text": "Cualquiera", "points": 3}]
              }
            ]
          }
        ]
